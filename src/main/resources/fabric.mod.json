{
  "schemaVersion": 1,
  "id": "breached",
  "version": "${version}",
  "name": "Breached",
  "description": "A Rust-inspired competitive survival, PvP, raiding, and base-building mod.",
  "authors": [
    "Broc Nerdin (3rdNerd)"
  ],
  "contact": {
    "email": "brocnerdin@gmail.com"
  },
  "license": "All-Rights-Reserved",
  "icon": "assets/breached/textures/item/netherite_breacher.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "nrd.breached.client.BreachedDataGenerator"
    ],
    "client": [
      "nrd.breached.client.BreachedClient"
    ],
    "main": [
      "nrd.breached.Breached"
    ]
  },
  "mixins": [
    "breached.mixins.json",
    {
      "config": "breached.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
